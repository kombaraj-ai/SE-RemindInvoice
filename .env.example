# ===========================
# RemindInvoice Environment
# Copy to .env and fill in
# ===========================

# --- Database ---
DB_USER=postgres
DB_PASSWORD=changeme
DB_NAME=remindinvoice
DATABASE_URL=postgresql://postgres:changeme@localhost:5432/remindinvoice

# --- Auth ---
SECRET_KEY=change-this-to-a-long-random-secret-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# --- Email (SendGrid) ---
SENDGRID_API_KEY=
FROM_EMAIL=hello@remindinvoice.com
FROM_NAME=RemindInvoice

# --- Redis / Celery ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# --- Storage ---
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000
